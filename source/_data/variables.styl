// 深空青蓝 · NexT变量覆盖
// ==============================

// 全局配色 - 深空蓝基调
$body-bg-color = #0A0E1A
$content-bg-color = #111827
$sidebar-bg-color = #0A0E1A
$footer-bg-color = #0A0E1A

// 文字 - 深空冷蓝调
$text-color = #C9D1D9
