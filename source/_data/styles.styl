// 深空青蓝全局样式

body {
  background-color: #0D1117 !important;
  color: #C9D1D9;
}

.main-inner, .content-wrap {
  background-color: #161B22 !important;
}

.post-title-link, .post-title a {
  color: #58A6FF !important;
  &:hover {
    color: #79C0FF !important;
  }
}

.category-list-link, .tag-list-link, .posts-collapse .post-title-link {
  color: #58A6FF;
}

.tag-cloud a {
  color: #58A6FF !important;
  border: 1px solid #388BFD;
  &:hover {
    color: #79C0FF !important;
    border-color: #58A6FF;
  }
}

hr {
  border: 0;
  height: 1px;
  background-image: linear-gradient(to right, rgba(88, 166, 255, 0), rgba(88, 166, 255, 0.75), rgba(88, 166, 255, 0));
}

.site-author-image {
  border-radius: 4px !important;
  box-shadow: 0 0 20px rgba(88, 166, 255, 0.4);
}

.post-body img {
  box-shadow: 0 0 10px rgba(88, 166, 255, 0.15);
}

.posts-collapse .post-header::before {
  background-color: #58A6FF;
  box-shadow: 0 0 10px rgba(88, 166, 255, 0.5);
}

.sidebar-inner {
  background: #0D1117 !important;
}

.menu-item-active a, .menu-item a:hover {
  color: #58A6FF !important;
}

.btn {
  background-color: #388BFD;
  border-color: #58A6FF;
  &:hover {
    background-color: #58A6FF;
  }
}

code, pre {
  background-color: #161B22;
  border-color: #30363D;
}

.archive-title, .posts-collapse .collection-title {
  color: #58A6FF !important;
}

.page-number, .extend {
  color: #58A6FF;
  &:hover {
    color: #79C0FF;
  }
}

.footer, .post-copyright {
  color: #8B949E;
}

a {
  color: #58A6FF;
  &:hover {
    color: #79C0FF;
  }
}

blockquote {
  border-left-color: #388BFD;
  color: #8B949E;
}

thead th {
  background-color: #161B22;
  border-bottom-color: #30363D;
}

td {
  border-bottom-color: #30363D;
}

// Sidebar dark theme
.site-state-item {
  color: #C9D1D9;
}

.site-author-name, .site-description {
  color: #C9D1D9;
}

.links-of-author-item a {
  color: #58A6FF !important;
}
