// ==============================
// 深空青蓝 · 全面暗色主题
// ==============================

// --- 全局基础 ---
html, body
  background-color: #0D1117 !important
  color: #E6EDF3

::selection
  background: rgba(88,166,255,0.3)
  color: #F0F6FC

// --- 头部 Header ---
.header
  background: #0D1117 !important
  border-bottom: 1px solid #21262D

.site-brand-container
  background: #0D1117 !important

.brand
  color: #F0F6FC !important

.site-title
  color: #F0F6FC !important
  font-weight: 600

.site-subtitle
  color: #9CA3AF !important

// --- 导航菜单 ---
.site-nav
  background: #0D1117 !important

.menu-item a
  color: #9CA3AF !important
  border-bottom: 2px solid transparent
  &:hover
    color: #58A6FF !important
    background: rgba(88,166,255,0.08) !important

.menu-item-active a
  color: #58A6FF !important
  border-bottom-color: #58A6FF !important

// --- 主体布局 ---
.main-inner
  background: transparent !important

.content-wrap
  background: transparent !important

// --- 首页归档列表 ---
.archive-title
  color: #58A6FF !important
  font-weight: 600

.posts-collapse
  .post-header
    border-bottom: 1px solid #21262D
    padding: 12px 0
    &:hover
      background: rgba(88,166,255,0.04)
    .post-meta-line time
      color: #9CA3AF
      font-size: 13px
    .post-title-link
      color: #E6EDF3 !important
      font-weight: 500
      &:hover
        color: #9ECBFF !important

// --- 归档页面 ---
.posts-collapse::before
  background-color: #30363D !important

.posts-collapse .post-header::before
  background-color: #58A6FF !important
  box-shadow: 0 0 0 3px rgba(88,166,255,0.2)

.collection-title
  color: #58A6FF !important

.collection-header
  color: #9CA3AF !important

.collection-year
  .collection-header
    color: #F0F6FC !important
    font-weight: 700

.post-meta-container
  time
    color: #9CA3AF !important

// --- 文章页 ---
.post-block
  background: #161B22 !important
  border-radius: 8px
  padding: 32px
  margin-bottom: 24px
  border: 1px solid #21262D

.post-title
  color: #F0F6FC !important
  font-weight: 700

.post-title-link
  color: #E6EDF3 !important
  &:hover
    color: #9ECBFF !important

.post-meta
  color: #9CA3AF !important
  span
    color: #9CA3AF !important

.post-body
  color: #E6EDF3
  line-height: 1.8
  h1
    color: #F0F6FC
    font-weight: 700
  h2
    color: #E6EDF3
    font-weight: 600
  h3, h4, h5, h6
    color: #E6EDF3
    border-bottom-color: #21262D
  p
    color: #E6EDF3
  img
    border-radius: 6px
    box-shadow: 0 4px 16px rgba(0,0,0,0.3)

// --- 分类页 ---
.category-list-item
  a
    color: #E6EDF3 !important
    &:hover
      color: #9ECBFF !important

.category-list-count
  color: #9CA3AF !important

// --- 标签页 ---
.tag-cloud a
  color: #9CA3AF !important
  background: #21262D
  border: 1px solid #30363D
  border-radius: 4px
  padding: 4px 10px
  margin: 4px
  display: inline-block
  &:hover
    color: #9ECBFF !important
    background: rgba(88,166,255,0.1)
    border-color: #388BFD

// --- 链接 ---
a
  color: #58A6FF
  &:hover
    color: #9ECBFF

// --- 引用 ---
blockquote
  border-left: 3px solid #388BFD !important
  background: rgba(88,166,255,0.04) !important
  color: #9CA3AF !important

// --- 代码 ---
code
  background: #1C2128 !important
  color: #E6EDF3 !important
  border: 1px solid #30363D
  border-radius: 4px

pre
  background: #1C2128 !important
  border: 1px solid #30363D
  border-radius: 6px
  code
    border: none

.highlight
  background: #1C2128 !important
  border-radius: 6px

// --- 表格 ---
table
  border-color: #30363D
  th
    background: #161B22 !important
    color: #F0F6FC !important
    border-bottom-color: #30363D
  td
    border-bottom-color: #21262D
    color: #E6EDF3
  tr:hover td
    background: rgba(88,166,255,0.06)

// --- 分隔线 ---
hr
  border: none
  height: 1px
  background: linear-gradient(to right, transparent, #3D444D, transparent)

// --- 按钮 ---
.btn
  background: #21262D
  color: #E6EDF3
  border: 1px solid #3D444D
  border-radius: 6px
  &:hover
    background: #30363D
    color: #9ECBFF
    border-color: #388BFD

// --- 分页 ---
.pagination
  .page-number, .extend
    color: #9CA3AF !important
    background: #21262D !important
    border: 1px solid #3D444D
    border-radius: 4px
    &:hover
      color: #9ECBFF !important
      background: rgba(88,166,255,0.1) !important
      border-color: #388BFD
  .current
    color: #9ECBFF !important
    background: rgba(88,166,255,0.15) !important
    border-color: #388BFD

// --- 侧边栏 ---
.sidebar
  background: #0D1117 !important
  border-right: 1px solid #21262D

.sidebar-inner
  background: #0D1117 !important

.site-author-image
  border-radius: 6px !important
  border: 2px solid #30363D
  box-shadow: 0 0 16px rgba(88,166,255,0.15)

.site-author-name
  color: #F0F6FC !important

.site-description
  color: #9CA3AF !important

.site-state-item
  color: #9CA3AF
  .site-state-item-count
    color: #F0F6FC !important
  .site-state-item-name
    color: #9CA3AF !important

.links-of-author-item a
  color: #9CA3AF !important
  border-bottom-color: #21262D !important
  &:hover
    color: #9ECBFF !important

// --- 页脚 ---
.footer
  background: #0D1117 !important
  color: #6E7681 !important
  a
    color: #9CA3AF !important
    &:hover
      color: #9ECBFF !important

// --- 返回顶部 ---
.back-to-top
  background: #21262D !important
  color: #9CA3AF !important
  border: 1px solid #30363D
  &:hover
    color: #9ECBFF !important

// --- 搜索 ---
.search-box input
  background: #161B22 !important
  color: #E6EDF3 !important
  border: 1px solid #30363D
  &::placeholder
    color: #6E7681

// --- 文章底部 ---
.post-copyright
  background: rgba(88,166,255,0.04) !important
  border: 1px solid #21262D !important
  border-radius: 6px
  color: #9CA3AF

.post-nav
  .post-nav-item
    color: #9CA3AF !important
    &:hover
      color: #9ECBFF !important

// --- 相关文章 ---
.related-posts
  .related-post-title
    color: #F0F6FC !important
  .related-post-link
    color: #9ECBFF !important

// --- 阅读进度条 ---
.reading-progress-bar
  background: linear-gradient(90deg, #388BFD, #58A6FF, #79C0FF) !important

// --- GitHub角落 ---
.github-corner
  svg
    fill: #58A6FF !important
    color: #0D1117 !important

// --- 归档页封面图 ---
.post-gallery
  margin: 12px 0
  display: flex
  flex-wrap: wrap
  gap: 8px
  .post-gallery-image
    width: 120px
    height: 80px
    overflow: hidden
    border-radius: 6px
    border: 1px solid #30363D
    a
      display: block
      width: 100%
      height: 100%
      &:hover img
        transform: scale(1.05)
    img
      width: 100%
      height: 100%
      object-fit: cover
      transition: transform 0.3s ease

// --- 滚动条美化 ---
::-webkit-scrollbar
  width: 8px
  height: 8px

::-webkit-scrollbar-track
  background: #0D1117

::-webkit-scrollbar-thumb
  background: #30363D
  border-radius: 4px
  &:hover
    background: #484F58

// --- 隐藏顶部汉堡菜单 ---
.site-nav-toggle
  display: none !important

// --- 覆盖NexT内置darkmode变量 ---
@media (prefers-color-scheme: dark)
  :root
    --body-bg-color: #0D1117
    --content-bg-color: #161B22
    --card-bg-color: #1C2128
    --text-color: #E6EDF3
    --text-color-secondary: #9CA3AF
    --selection-bg: rgba(88,166,255,0.3)
    --selection-color: #F0F6FC
    --blockquote-color: #9CA3AF
    --link-color: #58A6FF
    --link-hover-color: #9ECBFF
    --brand-color: #58A6FF
    --brand-hover-color: #9ECBFF
    --table-row-odd-bg-color: #1C2128
    --table-row-hover-bg-color: rgba(88,166,255,0.06)
    --menu-item-bg-color: #21262D
    --theme-color: #58A6FF
    --btn-default-bg: #21262D
    --btn-default-color: #E6EDF3
    --btn-default-border-color: #3D444D
    --btn-default-hover-bg: #30363D
    --btn-default-hover-color: #9ECBFF
